<?xml version='1.0' encoding='utf-8'?>
<odoo>
   
    <record id="employeeKpi_view_tree" model="ir.ui.view">
        <field name="name">df.employee_kpi.view.tree</field>
        <field name="model">df.employee_kpi</field>
        <field name="arch" type="xml">
            <tree string ="Employee KPI">

                <field name ="code"/>
                <field name ="name"/>
                <field name ="date"/>
                <field name ="value"/>
                <field name ="department_id"/>
                
            </tree>
        </field>
    </record>

    
    <record id="employeekpi_view_form" model="ir.ui.view">
        <field name="name">df.employee_kpi.view.form</field>
        <field name="model">df.employee_kpi</field>
        <field name="arch" type="xml">
            <form string="Employee KPI">
                <sheet>
                    <group>
                        <field name ="code"/>
                        <field name ="name"/>
                    </group>
                    <group>
                        <field name ="date"/>
                        <field name ="value"/>
                        <field name ="department_id"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>


    <record id="employeekpi_view_search" model="ir.ui.view">
        <field name="name">df.employee_kpi.view.search</field>
        <field name="model">df.employee_kpi</field>
        <field name="arch" type="xml">
            <search string="Busqueda">

                <field name ="code"/>
                <field name ="name"/>
                <field name ="date"/>
                <field name ="department_id"/>
                
            </search>
        </field>
    </record>

    <!-- model.name action window -->
    <record id="employee_kpi_action" model="ir.actions.act_window">
        <field name="name">Employee KPI</field>
        <field name="res_model">df.employee_kpi</field>
        <field name="view_mode">tree,form</field>
  
    </record>


    <!-- Submenu -->
       <menuitem id="menu_df_employee_kpi"
              name="Employee KPI"
              parent="menu_dashfast_bi_root"
              action="employee_kpi_action"
              sequence="10"/>

</odoo>